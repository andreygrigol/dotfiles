{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "bottom",
  "spacing": 0,
  "height": 32,
  "modules-left": [
		"custom/arch",
		"hyprland/workspaces",
		"mpris"
	],
  "modules-center": ["clock"],
  "modules-right": [
    "group/expand",
    "custom/spacer",
    "pulseaudio",
	"custom/spacer",
	"bluetooth",
	"custom/spacer",
	"cpu",
	"custom/spacer",
	"memory",
  ],

  "clock": {
	"format": "{:%A %H:%M}",
	"tooltip-format": "<span size='15000'><tt>{calendar}</tt></span>",
	"calendar": {
		"mode": "month",
		"format": {
			"months": "<span color='#fe8019'><b>{}</b></span>",
			"weekdays": "<span color='#83a598'><b>{}</b></span>",
			"days": "<span color='#a89984'><b>{}</b></span>",
			"today": "<span color='#ebdbb2'><b>{}</b></span>",
		}
	},
	"on-click": "gnome-calendar",
},

  "custom/spacer": {
    "format": "⏽",
  },

    "mpris": {
        "format": "[   {status_icon} | {dynamic} ]",
        "interval": 1,
        "dynamic-len": 40,
		"player": "spotify",
        "status-icons": {
            "playing": "▶",
            "paused": "⏸",
            "stopped": ""
        },
        "dynamic-order": ["artist"]
    },

  "cpu": {
	"interval": 10,
    "format": "{}% ",
    "max-length": 10,
	"on-click": "kitty btop"
},

  "memory": {
    "interval": 30,
    "format": "{used:0.1f}G/{total:0.1f}G ",
	"on-click": "swaync-client -t -sw"
},

  "custom/arch": {
	"format": "󰣇",
	"tooltip": false,
	"on-click": "fuzzel"
},

  "hyprland/workspaces": {
    "format": "{icon}",
    "persistent-workspaces": {
      "*": 6,
    },
},

  "custom/expand": {
    "format": "",
    "tooltip": false,
  },

  "group/expand": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 600,
      "transition-to-left": true,
      "click-to-reveal": true,
    },
    "modules": ["custom/expand", "tray"],
  },

  "tray": {
    "icon-size": 12,
    "spacing": 12,
  },

  "pulseaudio": {
    "format": "{volume}% {icon}",
    "on-click": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "on-click-right": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +1%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -1%",
    "scroll-step": 5,
    "format-muted": "",
    "format-icons": {
      "default": ["", "", ""],
    },
  },

  "network": {
    "format-icons": ["󰤯", "󰤟", "󰤢", "󰤥", "󰤨"],
    "format-wifi": "{icon}   {essid} ({frequency} GHz)  ⇣{bandwidthDownBytes}  ⇡{bandwidthUpBytes}",
    "format-ethernet": "⇣{bandwidthDownBytes}  ⇡{bandwidthUpBytes}",
    "format-disconnected": "󰤮",
    "interval": 3,
    "spacing": 1,
    "tooltip": false,
  },

  "bluetooth": {
	// "controller": "controller1", // specify the alias of the controller if there are more than 1 on the system
	"format": "",
	"format-disabled": "", // an empty format will hide the module
	"format-connected": " {num_connections} connected",
	"tooltip-format": "{controller_alias}\t{controller_address}",
	"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
	"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
	"on-click": "blueman-manager"
	}
}
